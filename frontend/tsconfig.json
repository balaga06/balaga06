{
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",

    /* ✅ React FIX */
    "jsx": "react-jsx",
    "types": ["react", "react-dom"],

    /* ✅ Path Alias FIX */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    /* ✅ Strict + Stability */
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,

    /* ✅ Your existing */
    "ignoreDeprecations": "6.0"
  }
}